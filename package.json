{
	"name": "@creative-int/saya-plugins",
	"version": "0.1.0",
	"private": true,
	"description": "Saya Cursor, Codex, and Claude Code plugin manifests, the saya-team-brain usage skill, and central remote MCP wiring — generated from one canonical config.",
	"keywords": [
		"saya",
		"mcp",
		"team-memory",
		"slack",
		"agent-context"
	],
	"homepage": "https://saya.computer",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/creative-int/saya-plugins.git"
	},
	"type": "module",
	"files": [
		".claude-plugin",
		".codex-plugin",
		".cursor-plugin",
		".mcp.json",
		"server.json",
		"LICENSE",
		"README.md",
		"assets/logo.png",
		"skills"
	],
	"scripts": {
		"generate": "node tooling/generate.ts",
		"check:generated": "node tooling/generate.ts --check",
		"typecheck": "tsc --noEmit",
		"build": "pnpm run typecheck",
		"help": "node tooling/generate.ts --help && node tooling/smoke.ts --help",
		"smoke": "node tooling/smoke.ts",
		"verify": "pnpm run check:generated && pnpm run typecheck && pnpm run build && pnpm run help && pnpm run smoke"
	},
	"devDependencies": {
		"@types/node": "^22.15.0",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.28.2",
	"engines": {
		"node": ">=22 <23",
		"pnpm": ">=10.28.2"
	}
}
